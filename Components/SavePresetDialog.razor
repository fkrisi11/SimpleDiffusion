@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="PresetName" Label="Preset Name" Required="true" AutoFocus="true" Variant="Variant.Outlined" Class="mt-2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(PresetName)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string PresetName { get; set; } = "";

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(PresetName));
}
