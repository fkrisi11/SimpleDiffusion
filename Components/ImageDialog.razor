@inject IJSRuntime JS
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject SimpleDiffusion.Components.Services.CrossTab CrossTab
@inject SimpleDiffusion.Components.Services.UiPreferences Prefs
@implements IDisposable
@using System.Globalization;

<MudDialog Gutters="false" Class="gallery-full-override" @onkeydown="HandleKeyDown">
    <DialogContent>
        <div class="gallery-wrapper @(_chromeHidden ? "chrome-hidden" : "")">

            @* Top Toolbar (single row, right aligned) *@
            <div class="gallery-toolbar">
                <div class="gallery-toolbar-right">

                    @if (HasImages && !IsVideo(CurrentImage))
                    {
                        <SendMenu Resolve="ResolveCurrentBase64" OnSent="@(() => MudDialog.Close())"
                                  Variant="Variant.Text" Color="Color.Inherit" Class="gallery-close-btn mr-1" />

                        <MudIconButton Icon="@Icons.Material.Filled.BookmarkAdd"
                                       Color="Color.Inherit"
                                       Size="Size.Small"
                                       title="Save to gallery"
                                       OnClick="SaveToGallery"
                                       Class="gallery-close-btn mr-1" />

                        <MudIconButton Icon="@Icons.Material.Filled.AutoAwesomeMotion"
                                       Color="Color.Inherit"
                                       Size="Size.Small"
                                       title="Make variations"
                                       OnClick="MakeVariations"
                                       Class="gallery-close-btn mr-1" />

                        @if (_canShare)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.IosShare"
                                           Color="Color.Inherit"
                                           Size="Size.Small"
                                           title="Share"
                                           OnClick="ShareImage"
                                           Class="gallery-close-btn mr-1" />
                        }
                    }

                    <MudIconButton Icon="@(_zoomed ? Icons.Material.Filled.ZoomOut : Icons.Material.Filled.ZoomIn)"
                                   Color="Color.Inherit"
                                   Size="Size.Small"
                                   OnClick="ToggleZoom"
                                   Class="gallery-close-btn mr-1" />

                    <MudChip T="bool" Variant="Variant.Filled"
                             Color="Color.Default"
                             Class="gallery-count-chip"
                             Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.Collections" Class="mr-1" />
                        @(HasImages ? SelectedIndex + 1 : 0) / @AllImages.Count
                    </MudChip>

                    @if (HasImages)
                    {
                        @if (IsVideo(CurrentImage))
                        {
                            <MudIconButton Icon="@(_galleryMuted ? Icons.Material.Filled.VolumeOff : Icons.Material.Filled.VolumeUp)"
                                           Color="Color.Inherit"
                                           Size="Size.Small"
                                           Class="gallery-close-btn mr-1"
                                           title="@(_galleryMuted ? "Unmute" : "Mute")"
                                           OnClick="ToggleGalleryMute" />

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.FileDownload"
                                       Size="Size.Small"
                                       Class="gallery-btn"
                                       OnClick="DownloadVideo">
                                Video
                            </MudButton>
                        }
                        else
                        {
                            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.FileDownload"
                                               EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                               Size="Size.Small"
                                               Class="gallery-btn">
                                        Download
                                    </MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Image" OnClick="DownloadImagePng">PNG</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Photo" OnClick="DownloadImageJpeg">JPG</MudMenuItem>
                                </ChildContent>
                            </MudMenu>
                        }
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Medium"
                                   Class="gallery-close-btn"
                                   OnClick="@(() => MudDialog.Close())" />
                </div>
            </div>

            @* Per-image caption (e.g. "Original" vs an upscaler name), when the opener supplied one. *@
            @if (CurrentCaption is { Length: > 0 } cap)
            {
                <div class="gallery-caption">@cap</div>
            }

            @* The Simplified Carousel. Pan/pinch/swipe/zoom are handled in JS on the gesture root
               (sdLightbox) to avoid a SignalR round-trip per pointermove — that made panning crawl
               on mobile. JS mutates the .drag-track / .media-container transforms directly. *@
            <div class="gallery-gesture" @ref="_gestureRoot">
                <MudCarousel Class="flex-grow-1 gallery-carousel"
                             @bind-SelectedIndex="SelectedIndex"
                             ShowBullets="false"
                             ShowArrows="@(!_chromeHidden)"
                             AutoCycle="false"
                             TData="string"
                             EnableSwipeGesture="false">
                    @foreach (var (imgBase64, index) in AllImages.Select((val, idx) => (val, idx)))
                    {
                        <MudCarouselItem Transition="Transition.None">
                            <div class="slide-container">
                                @if (SelectedIndex == index && !_mediaLoaded)
                                {
                                    <div class="lightbox-spinner"><MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Inherit" /></div>
                                }
                                <div class="drag-track">
                                    @if (SelectedIndex == index)
                                    {
                                        <div class="media-container">
                                            @if (IsVideo(imgBase64))
                                            {
                                                <video class="full-lightbox-img"
                                                       src="@imgBase64"
                                                       autoplay
                                                       muted
                                                       loop
                                                       playsinline
                                                       @onloadeddata="OnMediaLoaded" />
                                            }
                                            else
                                            {
                                                var displaySrc = DisplaySrc(imgBase64);
                                                @if (!string.IsNullOrEmpty(displaySrc))
                                                {
                                                    <img class="full-lightbox-img"
                                                         src="@displaySrc"
                                                         decoding="async"
                                                         draggable="false"
                                                         @onload="OnMediaLoaded"
                                                         @onerror="OnMediaLoaded" />
                                                    @* Phase 2 crisp-on-zoom overlay. Intentionally has no src binding — the JS
                                                       gesture controller sets/clears its src so Blazor re-renders never clobber it. *@
                                                    <img class="zoom-detail-layer" decoding="async" />
                                                }
                                            }
                                            <div class="media-overlay"></div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </MudCarouselItem>
                    }
                </MudCarousel>
            </div>

            @* Metadata bottom sheet: a translucent, blurred panel that slides up over the image.
               Tap/swipe the bottom "Info" peek to open; drag the grabber down (or tap the backdrop)
               to dismiss. Gestures are handled in JS (sdMetaSheet) to avoid SignalR-per-move lag. *@
            @if (HasImages)
            {
                <div class="meta-backdrop @(_metaOpen ? "open" : "")" @ref="_metaBackdrop" @onclick="@(() => SetMetaOpen(false))"></div>

                <div class="meta-peek @(_metaOpen || IsVideo(CurrentImage) ? "hidden" : "")" @ref="_metaPeek">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Class="mr-1" />
                    <span>Info</span>
                </div>

                <div class="meta-sheet @(_metaOpen ? "open" : "")" @ref="_metaSheet">
                    <div class="meta-grabber" @ref="_metaGrabber"><span class="meta-grabber-bar"></span></div>
                    <div class="meta-sheet-header">
                        <span class="meta-sheet-title"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2 mb-n1" />Image metadata</span>
                        <div class="d-flex align-center">
                            @if (!string.IsNullOrWhiteSpace(_metaText))
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Color="Color.Inherit" title="Copy" OnClick="CopyMetadata" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Inherit" OnClick="@(() => SetMetaOpen(false))" />
                        </div>
                    </div>
                    <div class="meta-sheet-body">
                        @if (_metaLoading)
                        {
                            <div class="d-flex justify-center pa-4"><MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Inherit" /></div>
                        }
                        else if (string.IsNullOrWhiteSpace(_metaText))
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No embedded generation metadata in this image.</MudAlert>
                        }
                        else
                        {
                            <div class="meta-sheet-text">@_metaText</div>
                        }
                    </div>
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] MudBlazor.IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<string> AllImages { get; set; } = new();
    /// <summary>Optional per-image labels (parallel to AllImages), shown as an overlay — used by the
    /// upscale comparison to mark "Original" vs each upscaler.</summary>
    [Parameter] public List<string>? Captions { get; set; }

    private string? CurrentCaption =>
        Captions is { Count: > 0 } && _selectedIndex >= 0 && _selectedIndex < Captions.Count
            ? Captions[_selectedIndex] : null;

    private int _selectedIndex;
    [Parameter]
    public int SelectedIndex
    {
        get => _selectedIndex;
        set
        {
            if (_selectedIndex != value)
            {
                _selectedIndex = value;
                // New media: re-apply the saved mute preference and show the loading spinner.
                _needAudioProbe = true;
                _mediaLoaded = false;
                // Drop any client-downscaled source from the previous slide.
                _optimizedSrc = null;
                _optimizedForKey = null;
            }
        }
    }

    // AllImages can change/shrink while the dialog is open (e.g. a new generation replaces it),
    // so never index it raw — clamp the index and read through these.
    private bool HasImages => AllImages is { Count: > 0 };
    private string? CurrentImage => HasImages ? AllImages[Math.Clamp(_selectedIndex, 0, AllImages.Count - 1)] : null;

    protected override void OnParametersSet()
    {
        // Keep the index in range whenever the list changes so render never throws.
        _selectedIndex = AllImages.Count == 0 ? 0 : Math.Clamp(_selectedIndex, 0, AllImages.Count - 1);
    }

    // Gallery audio state (the lightbox is the one place videos may play sound).
    private bool _galleryMuted = true;
    private bool _needAudioProbe = true;
    private bool _mediaLoaded;
    private bool _zoomed; // mirrors the JS gesture controller, for the toolbar icon

    // ---- Gallery image optimization (per-device toggle: Prefs.OptimizeLargeImages) ----
    // The long-edge size of the display tier we request/produce, sized to THIS device (set from JS in
    // OnInitializedAsync). A phone fetches ~1200-1700px instead of 2560, slashing transfer time over
    // wifi while staying crisp full-screen. 0 = not measured yet (gate rendering until known).
    private int _tierWidth;
    private string? _optimizedSrc;     // client-downscaled data URL for an in-memory (base64) image
    private string? _optimizedForKey;  // which image _optimizedSrc was computed for

    /// <summary>Resolve the &lt;img&gt; src for the current slide, honoring the optimization toggle.
    /// Stored gallery images get a device-sized server JPEG tier (<c>?w=</c>); in-memory base64 images
    /// get a client-downscaled data URL (computed in <see cref="OnAfterRenderAsync"/>); everything else
    /// is served as-is. Returns null while the tier width or a base64 downscale is still pending, so
    /// the spinner shows instead of fetching/decoding the full-size original.</summary>
    private string? DisplaySrc(string img)
    {
        if (string.IsNullOrEmpty(img)) return "";
        if (!Prefs.OptimizeLargeImages) return GetImageSrc(img);

        if (img.StartsWith("/gallery/file", StringComparison.OrdinalIgnoreCase)
            || img.StartsWith("/results/file", StringComparison.OrdinalIgnoreCase))
        {
            if (_tierWidth <= 0) return null; // wait until we know the device-appropriate width
            return img + (img.Contains('?') ? "&" : "?") + "w=" + _tierWidth;
        }

        // In-memory base64 / data URL (a just-generated result, not on disk).
        if (!img.StartsWith("/") && !img.StartsWith("http"))
            return _optimizedSrc; // null while the client downscale is pending

        // Other remote URLs (e.g. CivitAI) can't be resized cross-origin; leave untouched.
        return GetImageSrc(img);
    }

    protected override async Task OnInitializedAsync()
    {
        // Measure the device-appropriate tier width up front (before the first image renders) so we
        // never request an oversized JPEG. Falls back to a sane default if JS isn't ready.
        if (Prefs.OptimizeLargeImages)
        {
            try { _tierWidth = await JS.InvokeAsync<int>("sdImageOpt.tierWidth"); }
            catch { _tierWidth = 1600; }
            if (_tierWidth <= 0) _tierWidth = 1600;
        }
    }

    private ElementReference _gestureRoot;
    private ElementReference _metaBackdrop;
    private DotNetObjectReference<ImageDialog>? _selfRef;
    private bool _resetGesturesAfterRender;

    private bool _canShare;           // navigator can share files (set after first render)
    private bool _chromeHidden;       // tap the image to hide/show the toolbar & overlays

    // Metadata slide-up sheet state.
    private bool _metaOpen;
    private bool _metaLoading;
    private string? _metaText;
    private string? _metaRaw;         // raw A1111 parameters for the loaded image (for variations)
    private string? _metaLoadedFor;   // CurrentImage src the loaded text belongs to
    private bool _metaSheetBound;
    private ElementReference _metaSheet;
    private ElementReference _metaPeek;
    private ElementReference _metaGrabber;

    private void OnMediaLoaded()
    {
        if (!_mediaLoaded) { _mediaLoaded = true; StateHasChanged(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("sdLightbox.init", _gestureRoot, _selfRef, Prefs.LightboxSwipeUp, Prefs.LightboxSwipeDown, _metaBackdrop); } catch { }
            try
            {
                var can = await JS.InvokeAsync<bool>("sdShare.canShareFiles");
                if (can != _canShare) { _canShare = can; StateHasChanged(); }
            }
            catch { }
        }

        if (_resetGesturesAfterRender)
        {
            _resetGesturesAfterRender = false;
            try { await JS.InvokeVoidAsync("sdLightbox.reset", _gestureRoot); } catch { }
        }

        // When optimization is on, downscale an in-memory (base64) image on the SERVER (where the
        // bytes already live) and show a small tier URL — never push the full image to the phone to
        // decode. URL/remote images skip this (handled directly in DisplaySrc).
        if (Prefs.OptimizeLargeImages && HasImages && CurrentImage is { } curImg
            && !IsVideo(curImg) && !curImg.StartsWith("/") && !curImg.StartsWith("http")
            && _optimizedForKey != curImg)
        {
            _optimizedForKey = curImg;
            var edge = _tierWidth > 0 ? _tierWidth : 1600;
            try
            {
                // Run the decode/downscale on a background thread, not the circuit thread — a 16k
                // image takes seconds to decode, and doing it inline froze switching/closing the
                // viewer. The spinner shows until the tier URL is ready.
                var url = await Task.Run(() => SimpleDiffusion.Infrastructure.GalleryServer.CreateMemTierAsync(curImg, edge));
                _optimizedSrc = url ?? GetImageSrc(curImg); // null => image already small; show as-is
            }
            catch { _optimizedSrc = GetImageSrc(curImg); }
            StateHasChanged();
        }

        // Bind the bottom-sheet drag gestures once the elements exist (they render whenever there
        // are images). Re-bind if they were torn down (e.g. AllImages briefly emptied).
        if (HasImages && !_metaSheetBound && _selfRef != null)
        {
            try
            {
                await JS.InvokeVoidAsync("sdMetaSheet.init", _metaSheet, _metaPeek, _metaGrabber, _selfRef);
                _metaSheetBound = true;
            }
            catch { }
        }

        // If the sheet is open and the user paged to a different image, refresh the metadata.
        if (_metaOpen && !_metaLoading && _metaLoadedFor != CurrentImage)
        {
            await LoadMetaIfNeeded();
        }

        if (_needAudioProbe || firstRender)
        {
            _needAudioProbe = false;
            var cur = CurrentImage;
            if (cur is not null && IsVideo(cur))
            {
                try
                {
                    // Apply the saved per-device mute preference to the active video.
                    var muted = await JS.InvokeAsync<bool>("civGallery.applyPref");
                    if (muted != _galleryMuted) { _galleryMuted = muted; StateHasChanged(); }
                }
                catch { /* best-effort */ }
            }
        }
    }

    /// <summary>Called from the JS gesture controller on a committed swipe (dir: +1 next / -1 prev).</summary>
    [JSInvokable]
    public void Navigate(int dir)
    {
        if (!HasImages) return;
        SelectedIndex = dir > 0
            ? (SelectedIndex + 1) % AllImages.Count
            : (SelectedIndex == 0 ? AllImages.Count - 1 : SelectedIndex - 1);
        _resetGesturesAfterRender = true;
        StateHasChanged();
    }

    /// <summary>Called from JS when the zoom crosses 1.0, so the toolbar icon stays in sync.</summary>
    [JSInvokable]
    public void SetZoomed(bool zoomed)
    {
        if (_zoomed != zoomed) { _zoomed = zoomed; StateHasChanged(); }
    }

    /// <summary>Phase 2: called from the JS gesture controller when the user zooms in, to fetch a
    /// higher-resolution tier of the current image for crisp detail. Returns a tier URL (server JPEG
    /// for stored files, a /gallery/memtier for in-memory images) or null when no sharper tier applies
    /// (optimization off, remote URL, or the image is already small). <paramref name="edge"/> is the
    /// device-gated long-edge size the client decided it can handle.</summary>
    [JSInvokable]
    public async Task<string?> RequestZoomSrc(int edge)
    {
        if (!Prefs.OptimizeLargeImages) return null; // off => the base img is already full-res
        var cur = CurrentImage;
        if (cur is null || IsVideo(cur)) return null;
        edge = Math.Clamp(edge, 1024, 4096);
        try
        {
            if (cur.StartsWith("/gallery/file", StringComparison.OrdinalIgnoreCase))
                return cur + (cur.Contains('?') ? "&" : "?") + "w=" + edge;
            if (!cur.StartsWith("/") && !cur.StartsWith("http"))
                return await SimpleDiffusion.Infrastructure.GalleryServer.CreateMemTierAsync(cur, edge);
            return null; // remote URL (e.g. CivitAI) — can't resize
        }
        catch { return null; }
    }

    /// <summary>Called from the JS gesture controller on a clean single tap: toggle the UI chrome.</summary>
    [JSInvokable]
    public void ToggleChrome()
    {
        _chromeHidden = !_chromeHidden;
        StateHasChanged();
    }

    /// <summary>A configured vertical swipe (when not zoomed): close / toggle metadata. "none" never
    /// reaches here. A "close" swipe dismisses the metadata sheet first when it's open, so you don't have
    /// to close the whole viewer to get rid of it.</summary>
    [JSInvokable]
    public Task OnSwipeAction(string action)
    {
        if (action == "close")
            return _metaOpen ? SetMetaOpen(false) : InvokeAsync(() => MudDialog.Close());
        if (action == "metadata")
            return SetMetaOpen(!_metaOpen);
        return Task.CompletedTask;
    }

    private async Task ToggleZoom()
    {
        try { await JS.InvokeVoidAsync("sdLightbox.toggleZoom", _gestureRoot); } catch { }
    }

    /// <summary>Open or close the metadata sheet (loading the text on first open). Called from the
    /// toolbar Info button and, via JS interop, from the swipe/drag gesture.</summary>
    [JSInvokable]
    public Task SetMetaOpen(bool open) => InvokeAsync(async () =>
    {
        _metaOpen = open;
        try { await JS.InvokeVoidAsync("sdHaptic.buzz", 12); } catch { }
        if (open) await LoadMetaIfNeeded();
        else StateHasChanged();
    });

    /// <summary>Load embedded generation metadata for the current image (cached per image src).</summary>
    private async Task LoadMetaIfNeeded()
    {
        var src = CurrentImage;
        if (src is null) { _metaText = null; _metaLoadedFor = null; StateHasChanged(); return; }
        if (_metaLoadedFor == src) { StateHasChanged(); return; }

        _metaLoading = true;
        StateHasChanged();

        string? raw = null, upscaling = null, generated = null;
        try
        {
            if (src.StartsWith("/gallery/file", StringComparison.OrdinalIgnoreCase))
            {
                // A saved gallery image — let the server parse it (no full re-download).
                var res = await Http.GetFromJsonAsync<MetaResp>("/gallery/metadata" + src["/gallery/file".Length..]);
                raw = res?.Text;
                upscaling = res?.Upscaling;
                generated = res?.Generated;
            }
            else if (src.StartsWith("/") || src.StartsWith("http"))
            {
                var bytes = await Http.GetByteArrayAsync(src);
                raw = PngMetadata.ExtractParameters(bytes);
                upscaling = PngMetadata.ExtractText(bytes, "Upscaling");
                generated = PngMetadata.ExtractText(bytes, "Generation Time") ?? PngMetadata.ExtractText(bytes, "Creation Time");
            }
            else
            {
                raw = PngMetadata.ExtractParameters(src);            // base64 / data URL
                upscaling = PngMetadata.ExtractText(src, "Upscaling");
                generated = PngMetadata.ExtractText(src, "Generation Time") ?? PngMetadata.ExtractText(src, "Creation Time");
            }
        }
        catch { }

        _metaRaw = raw;
        _metaText = PngMetadata.FormatFull(raw, upscaling, generated) ?? "";
        _metaLoadedFor = src;
        _metaLoading = false;
        StateHasChanged();
    }

    private async Task CopyMetadata()
    {
        if (string.IsNullOrWhiteSpace(_metaText)) return;
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", _metaText); } catch { }
        try { await JS.InvokeVoidAsync("sdHaptic.buzz", 12); } catch { }
    }

    /// <summary>Save the current image into the app gallery (asks for an album when any exist).</summary>
    private async Task SaveToGallery()
    {
        if (CurrentImage is not { } src || IsVideo(src)) return;
        string b64;
        try
        {
            if (src.StartsWith("/") || src.StartsWith("http")) b64 = Convert.ToBase64String(await Http.GetByteArrayAsync(src));
            else if (src.StartsWith("data:")) b64 = src[(src.IndexOf(',') + 1)..];
            else b64 = src;
        }
        catch { return; }
        await GallerySaveFlow.RunAsync(DialogService, Http, Snackbar, b64);
    }

    /// <summary>Hand the current image to the OS share sheet (mobile). Falls back silently if the
    /// browser can't share files (the button only shows when it can).</summary>
    private async Task ShareImage()
    {
        if (CurrentImage is not { } cur || IsVideo(cur)) return;
        var fileName = $"SD_{DateTime.Now:yyyyMMdd_HHmmss}_{SelectedIndex}.png";
        try { await JS.InvokeVoidAsync("sdShare.shareImage", cur, fileName); } catch { }
    }

    /// <summary>Read this image's seed + prompt from its metadata and ask Home to generate seed
    /// variations of it (same prompt/seed, fresh subseed per image).</summary>
    private async Task MakeVariations()
    {
        if (CurrentImage is null || IsVideo(CurrentImage)) return;

        await LoadMetaIfNeeded();
        var seed = PngMetadata.ParseSeed(_metaRaw);
        if (seed is null)
        {
            Snackbar.Add("No seed found in this image's metadata — can't make variations.", Severity.Warning);
            return;
        }

        var dialog = await DialogService.ShowAsync<VariationsDialog>("Make variations",
            new DialogOptions { CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not ValueTuple<double, int> choice) return;

        var (positive, negative) = PngMetadata.ParsePrompts(_metaRaw);

        // Convert the source image to raw base64 so Home can keep it in the gallery next to its variants.
        string? originalB64 = null;
        try
        {
            var src = CurrentImage!;
            if (src.StartsWith("/") || src.StartsWith("http")) originalB64 = Convert.ToBase64String(await Http.GetByteArrayAsync(src));
            else if (src.StartsWith("data:")) originalB64 = src[(src.IndexOf(',') + 1)..];
            else originalB64 = src; // already raw base64
        }
        catch { }

        CrossTab.RequestVariations(new VariationsRequest(seed.Value, positive, negative, choice.Item1, choice.Item2, originalB64));
        MudDialog.Close();
    }

    private sealed class MetaResp { public string? Text { get; set; } public string? Upscaling { get; set; } public string? Generated { get; set; } }

    /// <summary>Resolve the current image to raw base64 (for the Send menu); handles URL/data/base64.</summary>
    private async Task<string?> ResolveCurrentBase64()
    {
        var src = CurrentImage;
        if (src is null || IsVideo(src)) return null;
        try
        {
            if (src.StartsWith("/") || src.StartsWith("http")) return Convert.ToBase64String(await Http.GetByteArrayAsync(src));
            if (src.StartsWith("data:")) return src[(src.IndexOf(',') + 1)..];
            return src; // raw base64
        }
        catch { return null; }
    }

    private async Task ToggleGalleryMute()
    {
        try { _galleryMuted = await JS.InvokeAsync<bool>("civGallery.toggleMute"); }
        catch { }
        StateHasChanged();
    }

    private async Task DownloadImagePng()
    {
        if (CurrentImage is not { } cur) return;
        try { await JS.InvokeVoidAsync("sdHaptic.buzz", 20); } catch { }
        var fileName = $"SD_{DateTime.Now:yyyyMMdd_HHmmss}_{SelectedIndex}.png";
        // The source is already a PNG, so never re-encode it (a 16k canvas re-encode is very slow and
        // can blow past canvas size limits). Stream the original file, or blob the base64 directly.
        if (cur.StartsWith("/") || cur.StartsWith("http"))
            await JS.InvokeVoidAsync("downloadUrl", cur, fileName);
        else
            await JS.InvokeVoidAsync("sdDownloadBase64", cur, "image/png", fileName);
    }

    private async Task DownloadImageJpeg()
    {
        if (CurrentImage is not { } cur) return;
        try { await JS.InvokeVoidAsync("sdHaptic.buzz", 20); } catch { }
        var fileName = $"SD_{DateTime.Now:yyyyMMdd_HHmmss}_{SelectedIndex}.jpg";
        // Our own stored/result images convert server-side via libvips (fast, cached, no canvas size
        // limits). Base64 / remote sources fall back to the client-side canvas conversion.
        if (cur.StartsWith("/gallery/file", StringComparison.OrdinalIgnoreCase)
            || cur.StartsWith("/results/file", StringComparison.OrdinalIgnoreCase))
            await JS.InvokeVoidAsync("downloadUrl", cur + (cur.Contains('?') ? "&" : "?") + "fmt=jpg", fileName);
        else
            await JS.InvokeVoidAsync("downloadConvertedFile", fileName, "image/jpeg", cur);
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { MudDialog.Close(); return; }
        if (!HasImages) return;
        if (e.Key == "ArrowRight") Navigate(1);
        else if (e.Key == "ArrowLeft") Navigate(-1);
    }

    private string GetImageSrc(string img)
    {
        if (string.IsNullOrEmpty(img)) return "";
        if (img.StartsWith("/") || img.StartsWith("http") || img.StartsWith("data:"))
            return img;
        return $"data:image/png;base64,{img}";
    }

    private bool IsVideo(string? src)
    {
        if (string.IsNullOrEmpty(src)) return false;

        // CRITICAL: this is called several times per render. For an in-memory result `src` is a raw
        // base64 blob (tens of MB), so never lowercase or scan the whole string — that allocated
        // hundreds of MB per render and stalled the circuit. Only URL-like sources can be videos;
        // a base64/data-image blob is decided by a cheap fixed-length prefix check.
        const StringComparison OIC = StringComparison.OrdinalIgnoreCase;
        bool urlLike = src.StartsWith('/') || src.StartsWith("http", OIC);
        if (!urlLike) return src.StartsWith("data:video", OIC);

        return src.EndsWith(".mp4", OIC) || src.EndsWith(".webm", OIC) ||
               src.Contains(".mp4?", OIC) || src.Contains(".webm?", OIC) ||
               src.Contains(".mp4&", OIC) || src.Contains(".webm&", OIC);
    }

    private async Task DownloadVideo()
    {
        if (CurrentImage is not { } url) return;
        var ext = url.ToLowerInvariant().Contains(".webm") ? "webm" : "mp4";
        var fileName = $"Video_{DateTime.Now:yyyyMMdd_HHmmss}_{SelectedIndex}.{ext}";
        await JS.InvokeVoidAsync("downloadUrl", url, fileName);
    }

    public void Dispose()
    {
        try { _ = JS.InvokeVoidAsync("sdLightbox.destroy", _gestureRoot); } catch { }
        try { _ = JS.InvokeVoidAsync("sdMetaSheet.destroy", _metaSheet); } catch { }
        _selfRef?.Dispose();
    }
}

