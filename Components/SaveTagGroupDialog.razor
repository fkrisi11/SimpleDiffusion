@using MudBlazor

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3 pa-1">
            <MudTextField @bind-Value="Name" Label="Group name" Required="true" AutoFocus="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Tags" Label="Tags" Variant="Variant.Outlined" Lines="6"
                          HelperText="Appended to the end of the prompt on a new line when loaded." />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(Name)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Tags { get; set; } = "";

    private void Cancel() => MudDialog.Cancel();

    private void Submit() =>
        MudDialog.Close(DialogResult.Ok(new TagGroup { Name = (Name ?? "").Trim(), Tags = (Tags ?? "").Trim() }));
}
