@using SimpleDiffusion.Components.Civitai
@implements IDisposable
@inject CivitaiDownloadManager Downloads
@inject UiPreferences Prefs

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Model.Name</MudText>
        <MudText Typo="Typo.caption">Choose a version to download</MudText>
    </TitleContent>

    <DialogContent>
        <MudList T="string" Dense="true">
            @foreach (var v in _versions)
            {
                var dl = Downloads.Get(v.Id);
                var onDisk = Downloads.IsDownloaded(v);
                var hasFile = v.PrimaryFile is not null;
                <MudListItem T="string">
                    <div class="vp-row">
                        <div class="vp-main">
                            <MudText Typo="Typo.body2" Class="vp-name">
                                @if (onDisk) { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-1" /> }
                                @v.Name
                                @if (IsNewer(v))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled" Class="ml-2">Newer</MudChip>
                                }
                            </MudText>
                            <MudText Typo="Typo.caption" Class="vp-sub">
                                @v.BaseModel @(v.PrimaryFile is { } f ? $"· {FormatKB(f.SizeKB)}" : "· no file")
                            </MudText>
                            @if (dl?.Status == DownloadStatus.Downloading)
                            {
                                <MudProgressLinear Value="@dl.Percent" Color="Color.Primary" Class="my-1" />
                            }
                            else if (dl?.Status == DownloadStatus.Failed)
                            {
                                <div class="vp-error"><b>Download failed:</b><br />@dl.Error</div>
                            }
                            else if (dl?.Status == DownloadStatus.Cancelled)
                            {
                                <div class="vp-error vp-warn">Cancelled</div>
                            }
                        </div>
                        <div class="vp-action">
                            @if (dl?.Status == DownloadStatus.Downloading)
                            {
                                <MudText Typo="Typo.caption">@dl.Percent.ToString("0")%</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Pause" Size="Size.Small"
                                               title="Pause" OnClick="@(() => Downloads.Pause(v.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               title="Cancel" OnClick="@(() => Downloads.Cancel(v.Id))" />
                            }
                            else if (dl?.Status == DownloadStatus.Paused)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small"
                                               title="Resume" OnClick="@(() => Downloads.Resume(v.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               title="Cancel" OnClick="@(() => Downloads.Cancel(v.Id))" />
                            }
                            else
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           Disabled="@(!hasFile)"
                                           OnClick="@(() => Download(v))">
                                    @(onDisk ? "Again" : "Get")
                                </MudButton>
                            }
                        </div>
                    </div>
                </MudListItem>
            }
        </MudList>
    </DialogContent>

    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.DownloadForOffline" OnClick="DownloadAll">
            Download all versions
        </MudButton>
        <MudButton OnClick="@(() => MudDialog.Close())">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .vp-row { display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center; width: 100%; }
    .vp-main { min-width: 0; }
    .vp-name { font-weight: 600; display: flex; align-items: center; }
    .vp-sub { opacity: 0.7; }
    .vp-error { display: block; margin-top: 4px; font-size: 12px; color: var(--mud-palette-error); word-break: break-word; }
    .vp-error.vp-warn { color: var(--mud-palette-warning); }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public CivitaiModel Model { get; set; } = default!;
    [Parameter] public List<string>? CompatibleBaseModels { get; set; }

    /// <summary>When set (update flow), versions published after this one are flagged "Newer".</summary>
    [Parameter] public int? CurrentVersionId { get; set; }

    private List<CivitaiModelVersion> _versions = new();
    private DateTimeOffset? _currentDate;

    private static DateTimeOffset? When(CivitaiModelVersion v) => v.PublishedAt ?? v.CreatedAt;

    private bool IsNewer(CivitaiModelVersion v)
    {
        if (CurrentVersionId is not { } cur || v.Id == cur) return false;
        return _currentDate is { } cd && When(v) is { } d && d > cd;
    }

    protected override void OnInitialized()
    {
        if (CurrentVersionId is { } id)
            _currentDate = When(Model.ModelVersions.FirstOrDefault(v => v.Id == id) ?? new CivitaiModelVersion());

        _versions = (CompatibleBaseModels is { Count: > 0 })
            ? Model.ModelVersions.Where(v => v.BaseModel is not null && CompatibleBaseModels.Contains(v.BaseModel)).ToList()
            : Model.ModelVersions.ToList();
        if (_versions.Count == 0) _versions = Model.ModelVersions.ToList();

        Downloads.Changed += OnChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await Prefs.EnsureLoadedAsync();
    }

    private void Download(CivitaiModelVersion v)
    {
        try { Downloads.Start(Model, v, Prefs.CivitaiApiKey); } catch { }
        StateHasChanged();
    }

    private void DownloadAll()
    {
        Downloads.StartAll(Model, Prefs.CivitaiApiKey);
        StateHasChanged();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Downloads.Changed -= OnChanged;

    private static string FormatKB(double kb)
    {
        string[] units = { "KB", "MB", "GB", "TB" };
        double v = kb;
        int u = 0;
        while (v >= 1024 && u < units.Length - 1) { v /= 1024; u++; }
        return $"{v:0.#} {units[u]}";
    }
}
