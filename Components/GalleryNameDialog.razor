@* Simple text-input dialog for creating / renaming albums. Returns the trimmed name. *@
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Value" Label="@Label" Variant="Variant.Outlined" Immediate="true"
                      Autofocus="true"
                      OnKeyDown="@(e => { if (e.Key == "Enter") Ok(); })" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Ok">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Label { get; set; } = "Album name";

    private void Ok()
    {
        var v = (Value ?? "").Trim();
        if (string.IsNullOrEmpty(v)) return;
        MudDialog.Close(DialogResult.Ok(v));
    }

    private void Cancel() => MudDialog.Cancel();
}
